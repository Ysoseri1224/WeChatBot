# 复制此文件为 .env 并填入真实的 API Key

# AI 供应商选择：gpt / deepseek / claude / minimax
AI_PROVIDER=gpt

# OpenAI GPT
GPT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
GPT_BASE_URL=https://api.openai.com/v1
GPT_MODEL=gpt-4o-mini

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-3-5-haiku-20241022

# MiniMax
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5-highspeed

# 系统 Prompt
SYSTEM_PROMPT=你是一个智能助手，请用中文简洁地回答用户的问题。

# 群聊白名单（逗号分隔群名）
GROUP_WHITELIST=书房

# 是否响应私聊
PRIVATE_CHAT_REPLY=true

# 群聊旁听缓冲区最大条数
GROUP_CONTEXT_LIMIT=50

# 微信文件缓存目录（改为你自己的 wxid）
WECHAT_FILE_DIR=D:\WeChat Files\你的wxid\FileStorage\File

# 长期记忆目录
MEMORY_DIR=D:\Weixin\bot\memory
